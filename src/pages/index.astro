---
import BaseLayout from '../layouts/BaseLayout.astro';
import AudioCard from '../components/AudioCard.astro';
import {
  buildHomeTitle, buildHomeDescription, buildHomeKeywords,
  buildSchemaWebsite, buildSchemaItemList, SITE_URL
} from '../lib/seo.js';
import soundsRaw from '../data/sounds.json';

const sounds = soundsRaw as any[];

// Build unique categories
const categoryMap = new Map<string, { name: string; slug: string; imageUrl: string | null; count: number }>();
sounds.forEach(s => {
  (s.categories || []).forEach((c: any) => {
    const k = c.slug || c.name;
    if (!categoryMap.has(k)) {
      categoryMap.set(k, { name: c.name, slug: c.slug || k, imageUrl: c.imageUrl || null, count: 0 });
    }
    categoryMap.get(k)!.count++;
  });
});
const categories = [...categoryMap.values()].sort((a, b) => b.count - a.count);

// Top sounds by plays
const featured = [...sounds].sort((a, b) => b.playCount - a.playCount).slice(0, 12);

// All sounds sorted by plays (for JS-filtered grid)
const allSounds = [...sounds].sort((a, b) => b.playCount - a.playCount);

const title = buildHomeTitle();
const description = buildHomeDescription();
const keywords = buildHomeKeywords();
const schema = [buildSchemaWebsite(), buildSchemaItemList(allSounds, '/')];

function fmtNum(n: number) {
  if (n >= 1e6) return (n / 1e6).toFixed(1) + 'M';
  if (n >= 1e3) return (n / 1e3).toFixed(1) + 'K';
  return String(n);
}
const totalPlays = sounds.reduce((s, d) => s + d.playCount, 0);
const totalDownloads = sounds.reduce((s, d) => s + d.downloadCount, 0);
---

<BaseLayout {title} {description} {keywords} {schema}>

  <!-- Minimal Hero: just a clean h1 + search -->
  <section class="hero" aria-labelledby="hero-heading">
    <div class="container" style="text-align:center;padding:48px 0 32px">
      <h1 id="hero-heading" style="font-size:clamp(1.8rem,5vw,3rem);font-weight:900;background:linear-gradient(135deg,#fff 30%,var(--accent3));-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin-bottom:28px">
        Telugu Meme Sounds
      </h1>

      <!-- Big search bar front and centre -->
      <div class="home-search-wrap" role="search" style="max-width:600px;margin:0 auto">
        <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <label for="home-search" class="sr-only">Search Telugu meme sounds</label>
        <input id="home-search" type="search"
               placeholder="Search 484+ sounds — e.g. Address pettu, Fahhhh, Sairam…"
               autocomplete="off" aria-label="Search Telugu meme sounds" />
      </div>
      <p id="search-count" aria-live="polite" style="margin-top:10px;font-size:0.8rem;color:var(--text3)"></p>
    </div>
  </section>

  <div class="container">

    <!-- Categories -->
    <section class="section" id="cats-section" aria-labelledby="cats-heading">
      <div class="section-header">
        <h2 class="section-title" id="cats-heading">Browse Categories</h2>
      </div>
      <div class="categories-grid">
        {categories.map(cat => (
          <a href={`/category/${cat.slug}`} class="cat-card" aria-label={`${cat.name} — ${cat.count} sounds`}>
            {cat.imageUrl
              ? <img src={cat.imageUrl} alt={cat.name} loading="lazy" />
              : <div class="cat-fallback">🎭</div>}
            <div class="cat-card-overlay">
              <div>
                <div class="cat-card-name">{cat.name}</div>
                <div class="cat-card-count">{cat.count} sounds</div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Trending (hidden while searching) -->
    <section class="section" id="trending-section" aria-labelledby="trending-heading">
      <div class="section-header">
        <h2 class="section-title" id="trending-heading">🔥 Trending Sounds</h2>
        <a href="/category/memes-trending-audios" class="section-link">View all →</a>
      </div>
      <div class="sounds-grid">
        {featured.map((s, i) => (
          <AudioCard sound={s} lazy={i > 3} />
        ))}
      </div>
    </section>

    <!-- All sounds — search results live here -->
    <section class="section" id="all-section" aria-labelledby="all-heading">
      <div class="section-header">
        <h2 class="section-title" id="all-heading">All Sounds</h2>
      </div>
      <div class="sounds-grid" id="all-sounds-grid">
        {allSounds.map((s, i) => (
          <div class="sound-search-item"
               data-title={s.title.toLowerCase()}
               data-tags={(s.tags || []).join(' ').toLowerCase()}
               data-cats={(s.categories || []).map((c: any) => c.name || c).join(' ').toLowerCase()}>
            <AudioCard sound={s} lazy={i > 11} />
          </div>
        ))}
      </div>
      <p id="no-results" style="display:none;text-align:center;padding:48px;color:var(--text3)">
        😕 No sounds found. Try a different search.
      </p>
    </section>

  </div>
</BaseLayout>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const input      = document.getElementById('home-search') as HTMLInputElement;
  const countEl    = document.getElementById('search-count')!;
  const noResults  = document.getElementById('no-results')!;
  const trending   = document.getElementById('trending-section')!;
  const catsSection= document.getElementById('cats-section')!;
  const allSection = document.getElementById('all-section')!;
  const allHeading = document.getElementById('all-heading')!;
  const items      = Array.from(document.querySelectorAll<HTMLElement>('.sound-search-item'));
  const total      = items.length;

  function updateSearch() {
    const q = input.value.toLowerCase().trim();
    const isSearching = q.length > 0;

    // Toggle categories + trending visibility while searching
    catsSection.style.display = isSearching ? 'none' : '';
    trending.style.display    = isSearching ? 'none' : '';
    allHeading.textContent    = isSearching ? `Search Results` : 'All Sounds';

    let visible = 0;
    items.forEach(item => {
      const match = !isSearching
        || (item.dataset.title || '').includes(q)
        || (item.dataset.tags  || '').includes(q)
        || (item.dataset.cats  || '').includes(q);
      item.style.display = match ? '' : 'none';
      if (match) visible++;
    });

    noResults.style.display = (isSearching && visible === 0) ? 'block' : 'none';
    countEl.textContent = isSearching
      ? `${visible} result${visible !== 1 ? 's' : ''} for "${input.value}"`
      : '';
  }

  input.addEventListener('input', updateSearch);

  // Pre-fill from URL ?q=
  const urlQ = new URLSearchParams(window.location.search).get('q');
  if (urlQ) { input.value = urlQ; updateSearch(); }

  // Also wire the header search form to redirect here with ?q=
  const headerForm = document.querySelector('.header-search') as HTMLFormElement;
  if (headerForm) {
    headerForm.addEventListener('submit', e => {
      e.preventDefault();
      const q = (headerForm.querySelector('input') as HTMLInputElement).value.trim();
      if (q) window.location.href = `/?q=${encodeURIComponent(q)}`;
    });
  }
});
</script>
