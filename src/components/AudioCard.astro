---
// AudioCard.astro — Reusable card component for a single sound
interface Props {
  sound: any;
  lazy?: boolean;
}
const { sound, lazy = true } = Astro.props;

const imgSrc = sound.thumbnailUrl || sound.categoryImageUrl || null;
const catSlug = sound.categories?.[0]?.slug || 'memes-trending-audios';
const catName = sound.categories?.[0]?.name || 'Meme Sound';

function fmtNum(n: number) {
  if (n >= 1e6) return (n / 1e6).toFixed(1) + 'M';
  if (n >= 1e3) return (n / 1e3).toFixed(1) + 'K';
  return String(n);
}
---

<article class="audio-card" itemscope itemtype="https://schema.org/AudioObject">
  <a href={`/sounds/${sound.slug}`} class="card-link" aria-label={`Play ${sound.title} meme sound`}>

    <!-- Thumbnail -->
    <div class="card-thumb">
      {imgSrc
        ? <img src={imgSrc} alt={`${sound.title} meme sound thumbnail`}
                loading={lazy ? 'lazy' : 'eager'} decoding="async"
                onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
                itemprop="thumbnailUrl" />
        : null}
      <div class="thumb-fallback" style={imgSrc ? 'display:none' : ''} aria-hidden="true">🎵</div>
      <div class="card-play-btn" aria-hidden="true">
        <svg width="22" height="22" fill="currentColor" viewBox="0 0 24 24">
          <path d="M8 5v14l11-7z"/>
        </svg>
      </div>
    </div>

    <!-- Body -->
    <div class="card-body">
      <h2 class="card-title" itemprop="name">{sound.title}</h2>
      <span class="card-cat">{catName}</span>

      {sound.tags?.length > 0 && (
        <div class="card-tags" aria-label="Tags">
          {sound.tags.slice(0, 3).map((tag: string) => (
            <span class="tag-pill">#{tag}</span>
          ))}
        </div>
      )}

      <div class="card-stats" aria-label="Sound statistics">
        <span title="Plays">
          <svg width="11" height="11" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
          {fmtNum(sound.playCount)}
        </span>
        <span title="Downloads">
          <svg width="11" height="11" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/></svg>
          {fmtNum(sound.downloadCount)}
        </span>
        <span title="Shares">
          <svg width="11" height="11" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92 1.61 0 2.92-1.31 2.92-2.92S19.61 16.08 18 16.08z"/></svg>
          {fmtNum(sound.shareCount)}
        </span>
      </div>
    </div>
  </a>
</article>
